{
  "name": "ho-branch-reconciliation",
  "version": "2.0.0",
  "description": "HO–Branch Inter-Company Ledger Reconciliation Engine",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.horecon.branch",
    "productName": "HO–Branch Reconciliation",
    "directories": { "output": "dist" },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "HO–Branch Recon"
    },
    "files": ["main.js","preload.js","src/**/*","assets/**/*","node_modules/**/*"]
  },
  "dependencies": { "xlsx": "^0.18.5" },
  "devDependencies": { "electron": "^28.0.0", "electron-builder": "^24.0.0" }
}
